# Sanity CMS — koppel later (https://sanity.io)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Resend e-mail — koppel later (https://resend.com)
RESEND_API_KEY=
# E-mailadres waar offerte-aanvragen heen gaan
OFFERTE_ONTVANGER=verkoop@weststrate.nl
# Afzender (moet een geverifieerd domein zijn in Resend)
OFFERTE_AFZENDER=offerte@weststrate.nl

# Swan-snelleverprogramma API — alleen nodig voor het sync-script
# (npm run sync) en de GitHub Action. NOOIT met NEXT_PUBLIC_ prefix:
# deze gegevens mogen nooit in de browser belanden.
SWAN_USERNAME=
SWAN_PASSWORD=
