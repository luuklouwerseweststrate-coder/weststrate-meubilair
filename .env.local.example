# Sanity CMS (https://sanity.io/manage). De twee NEXT_PUBLIC_-vars ook in
# Vercel zetten (Settings -> Environment Variables); zonder deze vars draait
# de site op de ingebouwde mock-data.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Token met Editor-rechten, alleen voor het seed-script (npm run seed).
# Aanmaken: project -> API -> Tokens. Blijft lokaal; NOOIT in de repo of
# in Vercel zetten (de site zelf leest alleen en heeft geen token nodig).
SANITY_API_TOKEN=

# Resend e-mail (https://resend.com) — gebruik dezelfde key als de
# bestekzakjes-configurator. Zet deze waarde in Vercel, niet in de repo.
RESEND_API_KEY=
# Feitelijk afleveradres van offerte-aanvragen. In testmodus levert Resend
# alleen op het account-adres (Luuks Gmail). Op de site tonen we
# info@weststrate.nl; verander dit naar het echte adres zodra het domein
# geverifieerd is.
OFFERTE_ONTVANGER=luuklouwerse.weststrate@gmail.com
# Afzender. In testmodus moet dit onboarding@resend.dev zijn; na verificatie
# van weststrate.nl mag het een eigen adres worden (bv. offerte@weststrate.nl).
OFFERTE_AFZENDER=onboarding@resend.dev

# Swan-snelleverprogramma API — alleen nodig voor het sync-script
# (npm run sync) en de GitHub Action. NOOIT met NEXT_PUBLIC_ prefix:
# deze gegevens mogen nooit in de browser belanden.
SWAN_USERNAME=
SWAN_PASSWORD=
